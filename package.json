{
  "name": "day-trader-os-web-service",
  "version": "1.0.0",
  "private": true,
  "description": "Render web service host for Day Trader OS static app + API routes",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:engine": "cd trading_engine && uvicorn main:app --host 0.0.0.0 --port 8000 --reload",
    "start:all": "concurrently --names \"WEB,BOT\" --prefix-colors \"cyan,yellow\" \"npm run start\" \"npm run start:engine\""
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
