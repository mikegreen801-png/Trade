<header class="top-app-bar">
  <div class="brand-lockup">
    <a class="brand-mark" href="index.html">Day Trader <span>OS</span></a>
    <p class="brand-subtitle">A calmer trading workspace</p>
  </div>
  <nav class="top-nav" aria-label="Primary navigation">
    {{{ primaryLinks }}}
  </nav>
  <div class="top-app-actions">
    <details class="more-menu">
      <summary>More</summary>
      <div class="more-panel">
        {{{ moreLinks }}}
      </div>
    </details>
    <div class="session-pill">
      <span data-session-label>Loading</span>
      <strong data-et-clock>--:-- ET</strong>
    </div>
    <a class="alert-nav-btn" href="market_intel.html#alerts" title="Price alerts" aria-label="Alerts">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
      <span id="alertNavBadge" class="alert-badge" style="display:none">0</span>
    </a>
    <div class="auth-slot" id="authSlot">
      <a class="auth-link" href="login.html">Sign in</a>
    </div>
  </div>
</header>
