<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }}</title>
  <meta name="description" content="{{ description }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="assets/app.css?v=20260516">
</head>
<body class="app-shell page-{{ pageId }}" data-dto-shell="modern" data-page-id="{{ pageId }}">
  {{{ topNav }}}
  <main class="page-shell">
    {{{ content }}}
    {{{ footer }}}
  </main>
  {{{ bottomNav }}}
  {{{ scripts }}}
</body>
</html>
