<section class="page-hero">
  <div class="hero-block">
    <span class="eyebrow">Practice</span>
    <h1>Backtest Simulator</h1>
    <p class="lead">Train your edge by replaying historical price action candle by candle.</p>
  </div>
  <aside class="hero-aside stack">
    <div class="metric-card">
      <span>Sim Status</span>
      <strong id="simStatus">Idle</strong>
      <small>Load a ticker to start.</small>
    </div>
    <div class="metric-card">
      <span>Session P&L</span>
      <strong id="simPnl" class="status-positive">$0.00</strong>
      <small>Current replay session.</small>
    </div>
    <div class="metric-card">
      <span>Win Rate</span>
      <strong id="simWinRate">--%</strong>
      <small>Trades taken.</small>
    </div>
  </aside>
</section>

<section class="market-grid">
  <article id="simChartContainer" class="surface section-anchor stack" style="grid-column: span 2;">
    <div class="section-header">
      <div style="display: flex; gap: 12px; align-items: center; flex-wrap: wrap;">
        <input id="simSymbol" type="text" placeholder="Symbol (e.g. AAPL)" style="width: 140px; padding: 6px 12px; border: 1px solid var(--border); border-radius: 6px;">
        <button class="secondary-btn" id="simLoadBtn" type="button">Load</button>
        <div style="width: 1px; height: 24px; background: var(--border); margin: 0 8px;"></div>
        <button class="secondary-btn" id="simPlayBtn" type="button" disabled>▶ Play</button>
        <button class="secondary-btn" id="simNextBtn" type="button" disabled>Next Candle</button>
        <button class="secondary-btn" id="simResetBtn" type="button" disabled>Reset</button>
      </div>
      <div style="display: flex; gap: 8px;">
        <button class="primary-btn" id="simBuyBtn" type="button" style="background-color: var(--green); border-color: var(--green);" disabled>Buy</button>
        <button class="primary-btn" id="simSellBtn" type="button" style="background-color: var(--red); border-color: var(--red);" disabled>Sell</button>
      </div>
    </div>
    
    <div style="width: 100%; height: 400px; background: #fafafa; border: 1px solid var(--border); border-radius: 8px; position: relative; overflow: hidden;">
      <canvas id="simCanvas" style="width: 100%; height: 100%;"></canvas>
      <div id="simOverlayMsg" style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); color: var(--text-soft); font-family: var(--font-sans); font-size: 14px;">Enter a symbol to load historical data.</div>
    </div>
    
    <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 16px; font-family: var(--font-mono); font-size: 13px; color: var(--text-soft);">
      <div>Price: <strong id="simCurrentPrice" style="color: var(--text-main);">--</strong></div>
      <div>Progress: <strong id="simProgress" style="color: var(--text-main);">0 / 0</strong></div>
      <div>Open Position: <strong id="simOpenPos" style="color: var(--text-main);">None</strong></div>
      <div>Unrealized: <strong id="simUnrealized">--</strong></div>
    </div>
  </article>

  <article id="simLogs" class="surface section-anchor stack" style="grid-column: span 2;">
    <div class="section-header">
      <div>
        <span class="eyebrow">Review</span>
        <h2>Session Trades</h2>
      </div>
    </div>
    <div class="table-container">
      <table class="data-table">
        <thead>
          <tr>
            <th>Side</th>
            <th>Entry</th>
            <th>Exit</th>
            <th>Net P&L</th>
          </tr>
        </thead>
        <tbody id="simLogsTableBody">
          <tr>
            <td colspan="4" class="empty-state" style="text-align: center; padding: 24px 0;">No trades taken yet in this session.</td>
          </tr>
        </tbody>
      </table>
    </div>
  </article>
</section>
