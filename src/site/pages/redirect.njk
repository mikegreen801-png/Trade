<section class="legacy-redirect">
  <article class="surface redirect-card stack">
    <span class="eyebrow">Moved</span>
    <h1>{{ redirectHeadline }}</h1>
    <p class="lead">{{ redirectCopy }}</p>
    <div class="button-row" style="justify-content:center">
      <a class="primary-btn" href="{{ redirectTarget }}">{{ redirectButton }}</a>
      <a class="secondary-btn" href="index.html">Go home</a>
    </div>
    <p class="footer-note">Redirecting now. Query parameters will be preserved.</p>
  </article>
</section>
