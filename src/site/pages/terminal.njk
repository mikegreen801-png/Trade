<section class="page-hero">
  <div class="hero-block">
    <span class="eyebrow">Institutional</span>
    <h1>Web Terminal</h1>
    <p class="lead">API-First interaction. Control the Day Trader OS headless architecture directly via CLI commands.</p>
  </div>
</section>

<section class="module-grid" style="grid-template-columns: 1fr;">
  <article class="surface stack" style="padding: 0; overflow: hidden; border: 1px solid var(--line);">
    <div class="section-header" style="padding: 16px 20px 0;">
      <div>
        <span class="eyebrow">Headless Control</span>
        <h2>Command Line Interface</h2>
      </div>
      <div style="display:flex; gap:8px;">
        <span class="mini-chip hold" id="termStatus">Disconnected</span>
      </div>
    </div>
    
    <div style="background: #000; padding: 12px; height: 500px; width: 100%;" id="terminal-container"></div>
  </article>
</section>

