<section class="login-shell">
  <article class="surface login-card stack">
    <!-- Sign-in state (shown when not logged in) -->
    <div id="loginFormState">
      <span class="eyebrow">Account</span>
      <h1 id="loginHeading">Sign in</h1>
      <p class="lead" id="loginSubtext">Sign in to save your Alpaca keys and keep your workspace in sync.</p>
      <form class="login-form" id="loginForm">
        <div class="field">
          <label for="loginEmail">Email</label>
          <input id="loginEmail" type="email" placeholder="trader@example.com" autocomplete="email" required>
        </div>
        <div class="field">
          <label for="loginPassword">Password</label>
          <input id="loginPassword" type="password" placeholder="Your password" autocomplete="current-password" required>
        </div>
        <button class="primary-btn" type="submit" id="loginSubmitBtn">Sign in</button>
      </form>
      <div class="login-toggle">
        <span id="loginToggleText">Don't have an account?</span>
        <a id="loginToggleLink">Create one</a>
      </div>
    </div>

    <!-- Logged-in state -->
    <div id="loginLoggedInState" style="display:none">
      <div class="user-greeting">
        <div class="auth-avatar" id="loginUserAvatar">M</div>
        <h2 id="loginUserName">Welcome back</h2>
        <p class="lead">You're signed in. Manage your Alpaca keys below.</p>
      </div>

      <div class="alpaca-config">
        <span class="eyebrow">Broker</span>
        <h3>Alpaca API keys</h3>
        <p class="lead" style="margin-top:0; margin-bottom:16px">Your keys are stored locally in this browser. They never leave your machine.</p>
        <form class="login-form" id="alpacaForm">
          <div class="field">
            <label for="alpacaKeyId">API Key ID</label>
            <input id="alpacaKeyId" type="text" placeholder="PK…" autocomplete="off">
          </div>
          <div class="field">
            <label for="alpacaSecret">Secret Key</label>
            <input id="alpacaSecret" type="password" placeholder="Your Alpaca secret" autocomplete="off">
          </div>
          <div class="field">
            <label for="alpacaEnv">Environment</label>
            <select id="alpacaEnv">
              <option value="paper">Paper (sandbox)</option>
              <option value="live">Live</option>
            </select>
          </div>
          <button class="primary-btn" type="submit">Save keys</button>
        </form>
        <div id="alpacaStatus" class="analysis-note" style="margin-top:16px">No keys saved yet.</div>
      </div>

      <button class="secondary-btn logout-btn" id="logoutBtn" type="button" style="width:100%">Sign out</button>
    </div>
  </article>
</section>
